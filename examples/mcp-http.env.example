# Copy to .env locally and fill in real values. Do not commit .env.
ADAPTORCH_CONTROL_PLANE_BASE_URL=https://adaptorch.ai.kr
ADAPTORCH_CONTROL_PLANE_TOKEN=<upstream-adaptorch-token-or-cloud-api-key>
ADAPTORCH_MCP_HTTP_AUTH_TOKEN=<client-facing-mcp-http-token>
ADAPTORCH_MCP_HTTP_HOST=127.0.0.1
ADAPTORCH_MCP_HTTP_PORT=8765
ADAPTORCH_MCP_TIMEOUT_SECONDS=30.0
