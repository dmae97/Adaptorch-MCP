# Copy to .env locally and fill in real values. Do not commit .env.
ADAPTORCH_CONTROL_PLANE_BASE_URL=<adaptorch-control-plane-url>
ADAPTORCH_CONTROL_PLANE_TOKEN=<upstream-adaptorch-token-or-cloud-api-key>
ADAPTORCH_MCP_HTTP_AUTH_TOKEN=<client-facing-mcp-http-token>

# Shell/template values for CLI flags. Pass these as --http-host/--http-port.
ADAPTORCH_MCP_HTTP_HOST=127.0.0.1
ADAPTORCH_MCP_HTTP_PORT=8765

# HTTP server controls delegated to adaptorch.mcp_server.
ADAPTORCH_MCP_ALLOWED_ORIGINS=http://127.0.0.1:8765
ADAPTORCH_MCP_MAX_PAYLOAD_SIZE_BYTES=1048576
ADAPTORCH_MCP_REQUEST_TIMEOUT_SECONDS=300.0
ADAPTORCH_MCP_MAX_SSE_SUBSCRIBERS=64

# Control-plane client timeout for embedded/app-factory usage.
ADAPTORCH_MCP_TIMEOUT_SECONDS=30.0

# --- Optional: AdaptOrch accuracy activation (delegated to the engine) ---
# Default is "off" (current behavior). Set a named profile only after the
# profile measures better for your deployment. Recommended candidate: max_accuracy.
# ADAPTORCH_ACCURACY_PROFILE=off            # off | balanced | max_accuracy
# Per-field overrides (win over the profile):
# ADAPTORCH_PARTIAL_CREDIT_PREFER_CONFIDENCE=1
# ADAPTORCH_JUDGE_OVERRIDE_MARGIN=0.15
# ADAPTORCH_VERIFICATION_CRITICAL_COMMANDS=pytest,test,build
# ADAPTORCH_VERIFICATION_CRITICAL_WEIGHT=5
